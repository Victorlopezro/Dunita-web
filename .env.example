# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URI=http://localhost:5173/auth/google/callback

# Email Configuration (Gmail for 2FA codes)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Existing Configuration (keep your existing values)
JWT_SECRET=your_jwt_secret
NODE_ENV=development

# Frontend Environment Variables (.env files in client folder or root)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_API_URL=http://localhost:5173
VITE_OAUTH_PORTAL_URL=http://localhost:3000
VITE_APP_ID=your_app_id
