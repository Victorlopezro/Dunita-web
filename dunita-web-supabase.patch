 4 files changed, 31 insertions(+), 22 deletions(-)
 create mode 100644 .env.example

diff --git a/.env.example b/.env.example
new file mode 100644
index 0000000..d6aa3b2
--- /dev/null
+++ b/.env.example
@@ -0,0 +1,5 @@
+DATABASE_URL="postgresql://user:password@host:port/database"
+JWT_SECRET="3Ivi4ZHzq0VfIl8/dReB+Lf5Ceun4HBiSBpTWBknAIA="
+VITE_APP_ID="dunita-web-app-default"
+OAUTH_SERVER_URL="https://your-railway-backend-url.railway.app"
+OWNER_OPEN_ID="default-owner-id"
diff --git a/client/src/main.tsx b/client/src/main.tsx
index 8adf6f5..aa6a943 100644
--- a/client/src/main.tsx
+++ b/client/src/main.tsx
